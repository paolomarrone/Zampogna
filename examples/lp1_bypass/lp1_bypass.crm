float y = delay (float x) {
	mem[1] float s
	y = s[0]
	s[0] = x
	s.init = x
}

pi = 3.141592653589793
pi2 = pi * 2.0

# Backward Euler method
y = lp1(x, s) {
	fc = 1000.0
	B0 = (pi2 * fc) / (fs + pi2 * fc)
	A1 = -fs / (fs + pi2 * fc)
	y = B0 * x - A1 * s
}


y = lp1_bypass(x, bypass) {
	y = if (bypass > 0.5) {
		y = x
	}
	else {
		s = if (delay(bypass) > 0.5) {
			s = delay(x)
		}
		else {
			s = delay(y)
		}
		s.init = 0.0
		y = lp1(x, s)
	}
}
